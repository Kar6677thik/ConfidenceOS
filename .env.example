# ConfidenceOS Environment Variables
# Copy this file to .env and fill in your values

# Direct Anthropic API key, or an OpenAI-compatible gateway key when
# LLM_PROVIDER=openai_compatible. LLM output is advisory only.
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional OpenAI-compatible gateway, for providers such as aicredits.in.
# Set OPENAI_COMPATIBLE_API_KEY only if you do not want to reuse ANTHROPIC_API_KEY.
LLM_PROVIDER=anthropic
OPENAI_COMPATIBLE_BASE_URL=https://aicredits.in/v1
OPENAI_COMPATIBLE_MODEL=anthropic/claude-3.5-haiku
OPENAI_COMPATIBLE_API_KEY=
AICREDITS_API_KEY=

# Database
DATABASE_URL=sqlite:////app/data/confidenceos.db

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8001

# Frontend
FRONTEND_PORT=5174
VITE_WS_URL=ws://localhost:8001/ws/sensors
VITE_API_URL=http://localhost:8001
