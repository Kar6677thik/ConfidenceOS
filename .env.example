# ConfidenceOS — environment variables for docker-compose deployment
# Copy this file to .env and fill in the values before running: docker compose up -d
# docker-compose reads .env from the same directory automatically.

# ── Auth ─────────────────────────────────────────────────────────────────────
# JWT signing secret — MUST be set to a stable value in production.
# Without it, a random secret is generated each restart, invalidating all
# existing tokens (users must log in again after every restart).
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
CONFIDENCEOS_JWT_SECRET=

# Token lifetime in hours (default: 8)
# CONFIDENCEOS_JWT_EXPIRY_HOURS=8

# ── LLM — AI-assisted features ───────────────────────────────────────────────
# Without a key, AI features (handover brief, root cause explainer, AI tag
# mapping) run in deterministic fallback mode. All safety logic and confidence
# scoring remain fully authoritative regardless.

# Recommended for Indian deployments: AICRedits.in (no international card needed)
# Get a key at https://aicredits.in — key format: sk-live-...
LLM_PROVIDER=openai_compatible
OPENAI_COMPATIBLE_API_KEY=sk-live-YOUR_KEY_HERE
OPENAI_COMPATIBLE_BASE_URL=https://aicredits.in/v1
OPENAI_COMPATIBLE_MODEL=anthropic/claude-3.5-haiku

# Alternative: direct Anthropic API (set LLM_PROVIDER=anthropic instead)
# ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# ── Database ─────────────────────────────────────────────────────────────────
# SQLite path inside the container (persisted via named volume — survives restarts).
# Only change if switching to PostgreSQL.
DATABASE_URL=sqlite:////app/data/confidenceos.db

# ── Ports ────────────────────────────────────────────────────────────────────
BACKEND_PORT=8001
FRONTEND_PORT=80
