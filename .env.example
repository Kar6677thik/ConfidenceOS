# ConfidenceOS Environment Variables
# Copy this file to .env and fill in your values

# Anthropic API Key (for Claude-powered Shift Handover Brief)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Database
DATABASE_URL=sqlite:////app/data/confidenceos.db

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8001

# Frontend
FRONTEND_PORT=5174
VITE_WS_URL=ws://localhost:8001/ws/sensors
VITE_API_URL=http://localhost:8001
