        "description": "Inflow and pump discharge flow validate whether indicated tank level is physically plausible."
      },
      {
        "id": "pump_vibration_device_health",
        "type": "device_health",
        "source_tags": ["VIB-101"],
        "validated_tag": "P-101",
        "description": "Pump vibration is device-health context for transfer operation reliability."
      }
    ],
    "affected_decisions": [
      {
        "id": "start_pump_decision",
